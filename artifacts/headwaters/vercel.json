{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "_comment": "STUB — committed for migration readiness. Review before deploying. See MIGRATION.md.",
  "buildCommand": "BASE_PATH=/headwaters/ pnpm --filter @workspace/headwaters run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "_comment": "Proxy /api/* to Fly.io API server",
      "source": "/api/:path*",
      "destination": "https://headwaters-watershed-api.fly.dev/api/:path*"
    },
    {
      "_comment": "SPA fallback",
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
